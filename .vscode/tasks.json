{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Husky & Commitlint",
      "type": "shell",
      "windows": {
        "command": "npm install --save-dev husky @commitlint/config-conventional @commitlint/cli; npx husky init; Set-Content -Path .husky/commit-msg -Value 'npx --no -- commitlint --edit $1'; Set-Content -Path .commitlintrc.json -Value '{\n  \"extends\": [\"@commitlint/config-conventional\"]\n}'"
      },
      "linux": {
        "command": "npm install --save-dev husky @commitlint/config-conventional @commitlint/cli && npx husky init && echo 'npx --no -- commitlint --edit $1' > .husky/commit-msg && echo '{\n  \"extends\": [\"@commitlint/config-conventional\"]\n}' > .commitlintrc.json"
      },
      "osx": {
        "command": "npm install --save-dev husky @commitlint/config-conventional @commitlint/cli && npx husky init && echo 'npx --no -- commitlint --edit $1' > .husky/commit-msg && echo '{\n  \"extends\": [\"@commitlint/config-conventional\"]\n}' > .commitlintrc.json"
      },
      "problemMatcher": [],
      "icon": {
        "id": "git-commit",
        "color": "terminal.ansiBlue"
      }
    },
    {
      "label": "Configure Semantic Release",
      "type": "shell",
      "windows": {
        "command": "npm install --save-dev semantic-release @semantic-release/changelog @semantic-release/git @semantic-release/github; Set-Content -Path .releaserc.json -Value '{\n  \"branches\": [\"main\"],\n  \"plugins\": [\n    \"@semantic-release/commit-analyzer\",\n    \"@semantic-release/release-notes-generator\",\n    \"@semantic-release/changelog\",\n    \"@semantic-release/github\",\n    [\"@semantic-release/git\", {\n      \"assets\": [\"package.json\", \"CHANGELOG.md\"],\n      \"message\": \"chore(release): ${nextRelease.version} [skip ci]\"\n    }]\n  ]\n}'"
      },
      "linux": {
        "command": "npm install --save-dev semantic-release @semantic-release/changelog @semantic-release/git @semantic-release/github && echo '{\n  \"branches\": [\"main\"],\n  \"plugins\": [\n    \"@semantic-release/commit-analyzer\",\n    \"@semantic-release/release-notes-generator\",\n    \"@semantic-release/changelog\",\n    \"@semantic-release/github\",\n    [\"@semantic-release/git\", {\n      \"assets\": [\"package.json\", \"CHANGELOG.md\"],\n      \"message\": \"chore(release): \\${nextRelease.version} [skip ci]\"\n    }]\n  ]\n}' > .releaserc.json"
      },
      "osx": {
        "command": "npm install --save-dev semantic-release @semantic-release/changelog @semantic-release/git @semantic-release/github && echo '{\n  \"branches\": [\"main\"],\n  \"plugins\": [\n    \"@semantic-release/commit-analyzer\",\n    \"@semantic-release/release-notes-generator\",\n    \"@semantic-release/changelog\",\n    \"@semantic-release/github\",\n    [\"@semantic-release/git\", {\n      \"assets\": [\"package.json\", \"CHANGELOG.md\"],\n      \"message\": \"chore(release): \\${nextRelease.version} [skip ci]\"\n    }]\n  ]\n}' > .releaserc.json"
      },
      "problemMatcher": [],
      "icon": {
        "id": "tag",
        "color": "terminal.ansiMagenta"
      }
    },
    {
      "label": "Initialize Full Environment (All-in-One)",
      "dependsOn": [
        "Create Project Layout",
        "Setup Husky & Commitlint",
        "Configure Semantic Release"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build"
      },
      "icon": {
        "id": "rocket",
        "color": "terminal.ansiCyan"
      }
    }
  ]
}
